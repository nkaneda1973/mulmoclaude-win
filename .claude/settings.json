{
  "permissions": {
    "allow": [
      "Bash(yarn test)",
      "Bash(yarn test *)",
      "Bash(yarn test:*)",
      "Bash(yarn lint)",
      "Bash(yarn lint *)",
      "Bash(yarn typecheck)",
      "Bash(yarn typecheck *)",
      "Bash(yarn format)",
      "Bash(yarn format *)",
      "Bash(sed -n *)",
      "Bash(ls *)",
      "mcp__mulmoclaude__readXPost"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "yarn build:packages && yarn format --check && yarn lint && yarn typecheck && yarn build && yarn test",
            "timeout": 300,
            "statusMessage": "Pre-commit checks (format/lint/typecheck/build/test)..."
          }
        ]
      }
    ]
  }
}
